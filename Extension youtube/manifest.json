{
  "manifest_version": 3,
  "name": "YouTuDo",
  "short_name": "YTDLPro",
  "version": "1.0.0",
  "description": "Téléchargez des vidéos YouTube dans tous les formats disponibles, avec fusion audio+vidéo (FFmpeg) pour 1080p et plus.",
  "permissions": [
    "downloads",
    "activeTab",
    "scripting",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "YouTuDo"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*", "*://*.youtube.com/shorts/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

